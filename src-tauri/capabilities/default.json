{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "allow-app-commands",
    "core:path:default",
    "core:webview:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select"
  ]
}
